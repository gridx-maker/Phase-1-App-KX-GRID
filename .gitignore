# ============================================================
# KXGRID — .gitignore
# ============================================================

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.*
*.env
*.key
credentials.json
token.json
.credentials
service_account.json

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
venv/
.venv/
env/
.Python
*.egg-info/
dist/
build/
.eggs/

# ─── Node / Frontend ─────────────────────────────────────────
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── React / Frontend Build ──────────────────────────────────
/frontend/build
/frontend/dist
/coverage
frontend/node_modules/.cache/

# ─── Production Builds ───────────────────────────────────────
/build
/out
dist/

# ─── IDE & Editors ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── System ──────────────────────────────────────────────────
*.pem
dump.rdb

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/

# ─── Archives & Large Assets ─────────────────────────────────
*.zip
*.tar.gz
*.tar
*.tgz
*.deb
*.dylib

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Next.js ─────────────────────────────────────────────────
/.next/

# ─── Deployment ──────────────────────────────────────────────
.vercel

# ─── Test Artifacts (auto-generated) ─────────────────────────
test_reports/
test_result.md

# ─── AI Agent State (Emergent platform leftovers) ────────────
.emergent/
memory/

# ─── Misc Dev Artifacts ──────────────────────────────────────
.cache/
.chainlit/
chainlit.md
.ipynb_checkpoints/
